    <!-- Dialogs/Permissions -->
    <string name="map_permission_title">मैप पिकर और इंटरनेट एक्सेस</string>
    <string name="map_permission_message">स्थान चुनने के लिए मैप दिखाने हेतु, MetaJammer को OpenStreetMap से मैप टाइल्स लोड करने के लिए इंटरनेट से जुड़ना होगा। \n\nयदि आप मना करते हैं, तो ऐप सभी मेटाडेटा हटाने और पॉइज़निंग सुविधाओं के लिए पूरी तरह से काम करना जारी रखेगा, लेकिन आप मैप पर विजुअल रूप से स्थान नहीं चुन पाएंगे।</string>
    <string name="allow_open_map">अनुमति दें और मैप खोलें</string>
    <string name="not_now">अभी नहीं</string>

    <string name="notification_permission_title">सूचित रहें</string>
    <string name="notification_permission_message">बैकग्राउंड में बड़ी फ़ाइलों के प्रोसेस होने के दौरान MetaJammer आपको प्रगति के बारे में अपडेट रखने के लिए सूचनाएं दिखा सकता है। \n\nयह विशेष रूप से तब उपयोगी होता है जब आप MetaJammer के अपना काम पूरा करने के दौरान किसी अन्य ऐप पर जाना चाहते हैं।</string>
