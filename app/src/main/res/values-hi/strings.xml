    <string name="feature_images_video_title">इमेज और वीडियो</string>
    <string name="feature_images_video_desc">फ़ोटो से मेटाडेटा हटाने और ट्रैकिंग हटाने के लिए वीडियो को रीमक्स करने का पूर्ण समर्थन।</string>
    <string name="feature_poisoning_title">मेटाडेटा पॉइज़निंग</string>
