    <string name="hero_subtitle">अपनी फ़ाइलें साझा करने से पहले संवेदनशील मेटाडेटा को साफ़ करें या बदलें।</string>
    <string name="feature_images_video_title">इमेज और वीडियो</string>
    <string name="feature_images_video_desc">फ़ोटो से मेटाडेटा हटाने और ट्रैकिंग हटाने के लिए वीडियो को रीमक्स करने का पूरा समर्थन।</string>
    <string name="feature_poisoning_title">मेटाडेटा पॉइज़निंग</string>
    <string name="feature_poisoning_desc">केवल डेटा न हटाएं—गोपनीयता बनाए रखने और ट्रैकर्स को भ्रमित करने के लिए इसे यथार्थवादी नकली डेटा से बदलें।</string>
    <string name="feature_background_title">बैकग्राउंड प्रोसेसिंग</string>
    <string name="feature_background_desc">जब आप अन्य काम करते हैं तो बैकग्राउंड में सैकड़ों फ़ाइलों को कुशलतापूर्वक प्रोसेस करें।</string>
    <string name="feature_on_device_title">ऑन-डिवाइस गोपनीयता</string>
