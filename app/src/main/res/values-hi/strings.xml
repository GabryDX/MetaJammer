    <!-- HelpScreen -->
    <string name="help_title">Help &amp; Tutorials</string>
    <string name="help_item_video_title">Video Processing</string>
    <string name="help_item_video_body">Supported formats: MP4, MOV.\n\nFull re-muxing is supported for these containers. This process strips GPS, dates, and device atoms to protect your privacy.</string>
    <string name="help_item_image_title">Image Processing</string>
    <string name="help_item_image_body">Supported formats: JPG, PNG.\n\nMetaJammer strips EXIF metadata from these images. In \"Poison\" mode, it replaces sensitive tags like GPS coordinates with realistic random data.</string>
    <string name="help_item_other_title">Other Files</string>
    <string name="help_item_other_body">Supported formats: None currently.\n\nMetaJammer currently focuses on media files. Future updates will include support for PDFs and documents. Stay tuned!</string>
    <string name="help_report_issue_title">Report an Issue</string>
    <string name="help_report_issue_body">Found a bug or have a feature request? Please report it on our GitHub page.</string>
