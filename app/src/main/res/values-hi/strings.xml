    <!-- Dialogs/Permissions -->
    <string name="map_permission_title">मानचित्र चयनकर्ता और इंटरनेट एक्सेस</string>
    <string name="map_permission_message">स्थान चुनने के लिए मानचित्र दिखाने के लिए, MetaJammer को OpenStreetMap से मानचित्र टाइल लोड करने के लिए इंटरनेट से कनेक्ट करने की आवश्यकता है। \n\nयदि आप अस्वीकार करते हैं, तो ऐप सभी मेटाडेटा हटाने और पॉइज़निंग सुविधाओं के लिए पूरी तरह से काम करना जारी रखेगा, लेकिन आप मानचित्र पर दृश्य रूप से स्थान नहीं चुन पाएंगे।</string>
    <string name="allow_open_map">अनुमति दें और मानचित्र खोलें</string>
    <string name="not_now">अभी नहीं</string>

    <string name="notification_permission_title">सूचित रहें</string>
    <string name="notification_permission_message">MetaJammer बैकग्राउंड में प्रोसेस होने के दौरान बड़े फ़ाइल बैचों की प्रगति के बारे में आपको अपडेट रखने के लिए सूचनाएं दिखा सकता है। \n\nयह विशेष रूप से तब उपयोगी होता है जब आप MetaJammer के अपना काम पूरा करने के दौरान किसी अन्य ऐप पर स्विच करना चाहते हैं।</string>
