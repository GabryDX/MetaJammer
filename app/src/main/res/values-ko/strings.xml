    <!-- HomeScreen -->
    <string name="hero_title">프라이버시 보호</string>
    <string name="hero_subtitle">파일을 공유하기 전에 민감한 메타데이터를 정리하거나 교체하세요.</string>
    <string name="feature_images_video_title">이미지 및 동영상</string>
    <string name="feature_images_video_desc">사진에서 메타데이터를 제거하고 동영상을 리먹싱하여 추적을 방지하는 기능을 완벽하게 지원합니다.</string>
    <string name="feature_poisoning_title">메타데이터 포이즈닝</string>
    <string name="feature_poisoning_desc">단순히 데이터를 제거하는 데 그치지 않고 실제와 유사한 가짜 데이터로 교체하여 프라이버시를 보호하고 추적기를 혼란스럽게 만듭니다.</string>
    <string name="feature_background_title">백그라운드 처리</string>
    <string name="feature_background_desc">다른 작업을 하는 동안 백그라운드에서 수백 개의 파일을 효율적으로 처리합니다.</string>
    <string name="feature_on_device_title">온디바이스 프라이버시</string>
    <string name="feature_on_device_desc">모든 처리는 기기 내에서 로컬로 수행됩니다. 귀하의 파일은 절대 MetaJammer를 떠나지 않습니다.</string>
