    <!-- HelpScreen -->
    <string name="help_title">帮助与教程</string>
    <string name="help_item_video_title">视频处理</string>
    <string name="help_item_video_body">支持的格式：MP4, MOV。\n\n这些格式支持完整的“重混”(Remuxing) 过程。该过程会删除 GPS、日期和设备信息，以保护您的隐私。</string>
    <string name="help_item_image_title">图像处理</string>
    <string name="help_item_image_body">支持的格式：JPG, PNG, WebP, HEIF。\n\nMetaJammer 会从这些图像中删除 EXIF 元数据。在“投毒”模式下，它会将 GPS 坐标等敏感标签替换为现实的随机数据。</string>
    <string name="help_item_other_title">PDF 和文档处理</string>
    <string name="help_item_other_body">支持的格式：PDF。\n\nMetaJammer 现在全面支持 PDF 文档。您可以读取、删除和伪造 (poison) 诸如标题、作者、主题、关键词、创建者和生成者等元数据，以确保您的文档在共享前保持洁净。</string>
    <string name="help_report_issue_title">报告问题</string>
    <string name="help_report_issue_body">发现了漏洞或有功能请求？请在我们的 GitHub 页面上报告。</string>
    <string name="help_open_github">打开 GitHub 问题</string>
