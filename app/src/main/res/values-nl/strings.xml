    <!-- HelpScreen -->
    <string name="help_title">Hulp &amp; Tutorials</string>
    <string name="help_item_video_title">Videoverwerking</string>
    <string name="help_item_video_body">Ondersteunde formaten: MP4, MOV.\n\nVolledige remuxing wordt ondersteund voor deze containers. Dit proces verwijdert GPS, datums en apparaat-atomen om uw privacy te beschermen.</string>
    <string name="help_item_image_title">Beeldverwerking</string>
    <string name="help_item_image_body">Ondersteunde formaten: JPG, PNG, WebP, HEIF.\n\nMetaJammer verwijdert EXIF-metadata van deze afbeeldingen. In de modus \"Poison\" worden gevoelige tags zoals GPS-coördinaten vervangen door realistische willekeurige gegevens.</string>
    <string name="help_item_other_title">PDF- &amp; documentverwerking</string>
    <string name="help_item_other_body">Ondersteunde formaten: PDF.\n\nMetaJammer ondersteunt nu volledig PDF-documenten. U kunt metadata zoals Titel, Auteur, Onderwerp, Trefwoorden, Maker en Producent lezen, verwijderen en \"vergiftigen\". Het verwijdert ook verborgen watermerken en annotaties om ervoor te zorgen dat uw documenten schoon zijn voordat u ze deelt.</string>
    <string name="help_report_issue_title">Meld een probleem</string>
    <string name="help_report_issue_body">Een bug gevonden of een verzoek voor een nieuwe functie? Meld het op onze GitHub-pagina.</string>
    <string name="help_open_github">GitHub Issues openen</string>
    <string name="help_app_version">Versie: %1$s</string>
