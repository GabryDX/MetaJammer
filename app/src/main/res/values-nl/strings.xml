    <!-- Dialogs/Permissions -->
    <string name="map_permission_title">Kaartkiezer &amp; internettoegang</string>
    <string name="map_permission_message">Om een kaart te tonen voor het kiezen van een locatie, moet MetaJammer verbinding maken met internet om kaarttegels van OpenStreetMap te laden. \n\nAls je weigert, blijft de app perfect werken voor alle functies voor het strippen en vergiftigen van metadata, maar kun je locaties niet visueel op een kaart kiezen.</string>
    <string name="allow_open_map">Toestaan &amp; Kaart openen</string>
    <string name="not_now">Niet nu</string>

    <string name="notification_permission_title">Blijf op de hoogte</string>
    <string name="notification_permission_message">MetaJammer kan meldingen tonen om je op de hoogte te houden van de voortgang van grote batches bestanden terwijl ze op de achtergrond worden verwerkt. \n\nDit is vooral handig als je naar een andere app wilt overschakelen terwijl MetaJammer klaar is met zijn werk.</string>
