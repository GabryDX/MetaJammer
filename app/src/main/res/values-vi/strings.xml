    <!-- Dialogs/Permissions -->
    <string name="map_permission_title">Chọn bản đồ &amp; Truy cập Internet</string>
    <string name="map_permission_message">Để hiển thị bản đồ chọn vị trí, MetaJammer cần kết nối internet để tải dữ liệu bản đồ từ OpenStreetMap.\n\nNếu bạn từ chối, ứng dụng vẫn hoạt động hoàn hảo cho mọi tính năng xóa và đầu độc siêu dữ liệu, nhưng bạn sẽ không thể chọn vị trí trực quan trên bản đồ.</string>
