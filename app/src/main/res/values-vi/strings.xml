    <string name="feature_images_video_title">Hình ảnh, Video, Âm thanh &amp; PDF</string>
    <string name="feature_images_video_desc">Hỗ trợ đầy đủ cho việc loại bỏ siêu dữ liệu khỏi ảnh và remux video, âm thanh và tài liệu PDF để loại bỏ theo dõi.</string>
    <string name="feature_poisoning_title">Đầu độc siêu dữ liệu</string>
    <string name="feature_poisoning_desc">Không chỉ xóa dữ liệu—hãy thay thế bằng dữ liệu giả thực tế để bảo vệ quyền riêng tư và gây nhiễu trình theo dõi.</string>
