    <string name="not_now">Để sau</string>

    <string name="notification_permission_title">Luôn cập nhật thông tin</string>
    <string name="notification_permission_message">MetaJammer có thể hiển thị thông báo để cập nhật cho bạn về tiến trình xử lý các lô tệp lớn khi chúng đang chạy nền.\n\nĐiều này đặc biệt hữu ích nếu bạn muốn chuyển sang ứng dụng khác trong khi MetaJammer hoàn tất công việc.</string>
