    <!-- Dialogs/Permissions -->
    <string name="map_permission_title">Επιλογέας Χάρτη &amp; Πρόσβαση στο Διαδίκτυο</string>
    <string name="map_permission_message">Για να εμφανιστεί ένας χάρτης για την επιλογή τοποθεσίας, το MetaJammer πρέπει να συνδεθεί στο διαδίκτυο για να φορτώσει πλακίδια χάρτη από το OpenStreetMap. \n\nΕάν αρνηθείτε, η εφαρμογή θα συνεχίσει να λειτουργεί τέλεια για όλες τις λειτουργίες αφαίρεσης και δηλητηρίασης μεταδεδομένων, αλλά δεν θα μπορείτε να επιλέξετε τοποθεσίες οπτικά σε έναν χάρτη.</string>
    <string name="allow_open_map">Να επιτρέπεται &amp; Άνοιγμα χάρτη</string>
    <string name="not_now">Όχι τώρα</string>

    <string name="notification_permission_title">Μείνετε ενημερωμένοι</string>
    <string name="notification_permission_message">Το MetaJammer μπορεί να εμφανίζει ειδοποιήσεις για να σας ενημερώνει για την πρόοδο μεγάλων παρτίδων αρχείων ενώ επεξεργάζονται στο παρασκήνιο. \n\nΑυτό είναι ιδιαίτερα χρήσιμο εάν θέλετε να μεταβείτε σε άλλη εφαρμογή ενώ το MetaJammer ολοκληρώνει την εργασία του.</string>
