    <!-- HelpScreen -->
    <string name="help_title">Βοήθεια και οδηγοί</string>
    <string name="help_item_video_title">Επεξεργασία βίντεο</string>
    <string name="help_item_video_body">Υποστηριζόμενες μορφές: MP4, MOV.\n\nΥποστηρίζεται πλήρης επαναπολυπλεξία για αυτούς τους περιέκτες. Αυτή η διαδικασία αφαιρεί το GPS, τις ημερομηνίες και τα άτομα της συσκευής για την προστασία του απορρήτου σας.</string>
    <string name="help_item_image_title">Επεξεργασία εικόνας</string>
    <string name="help_item_image_body">Υποστηριζόμενες μορφές: JPG, PNG, WebP, HEIF.\n\nΤο MetaJammer αφαιρεί τα μεταδεδομένα EXIF από αυτές τις εικόνες. Στη λειτουργία «Δηλητηρίαση», αντικαθιστά ευαίσθητες ετικέτες όπως οι συντεταγμένες GPS με ρεαλιστικά τυχαία δεδομένα.</string>
    <string name="help_item_other_title">Επεξεργασία PDF &amp; Εγγράφων</string>
    <string name="help_item_other_body">Υποστηριζόμενες μορφές: PDF.\n\nΤο MetaJammer υποστηρίζει πλέον πλήρως έγγραφα PDF. Μπορείτε να διαβάσετε, να αφαιρέσετε και να αλλοιώσετε (poison) μεταδεδομένα όπως Τίτλος, Συγγραφέας, Θέμα, Λέξεις-κλειδιά, Δημιουργός και Παραγωγός, ώστε να διασφαλίσετε ότι τα έγγραφά σας είναι καθαρά πριν από την κοινή χρήση.</string>
    <string name="help_report_issue_title">Αναφορά προβλήματος</string>
    <string name="help_report_issue_body">Βρήκατε κάποιο σφάλμα ή έχετε ένα αίτημα για λειτουργία; Παρακαλούμε αναφέρετέ το στη σελίδα μας στο GitHub.</string>
