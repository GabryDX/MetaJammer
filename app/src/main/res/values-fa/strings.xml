    <!-- Dialogs/Permissions -->
    <string name="map_permission_title">انتخابگر نقشه و دسترسی به اینترنت</string>
    <string name="map_permission_message">برای نمایش نقشه جهت انتخاب مکان، MetaJammer باید به اینترنت متصل شود تا کاشی‌های نقشه را از OpenStreetMap بارگذاری کند. \n\nاگر نپذیرید، برنامه برای تمام ویژگی‌های پاکسازی و مسموم‌سازی متاداده به خوبی کار خواهد کرد، اما نمی‌توانید مکان‌ها را به‌صورت بصری روی نقشه انتخاب کنید.</string>
