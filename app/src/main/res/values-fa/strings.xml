    <string name="feature_images_video_title">تصاویر، ویدیو، صدا و PDF</string>
    <string name="feature_images_video_desc">پشتیبانی کامل از حذف متادیتا از عکس‌ها و ریمکس کردن ویدیوها، صداها و اسناد PDF برای حذف ردیابی.</string>
    <string name="feature_poisoning_title">مسموم‌سازی متاداده</string>
