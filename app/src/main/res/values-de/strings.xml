    <!-- Dialogs/Permissions -->
    <string name="map_permission_title">Karten-Picker &amp; Internetzugang</string>
    <string name="map_permission_message">Um eine Karte zur Standortwahl anzuzeigen, muss MetaJammer eine Verbindung zum Internet herstellen, um Kartenkacheln von OpenStreetMap zu laden. \n\nWenn du ablehnst, funktioniert die App weiterhin einwandfrei für alle Funktionen zum Entfernen und Vergiften von Metadaten, aber du kannst Standorte nicht visuell auf einer Karte auswählen.</string>
    <string name="allow_open_map">Zulassen &amp; Karte öffnen</string>
    <string name="not_now">Nicht jetzt</string>

    <string name="notification_permission_title">Bleib informiert</string>
    <string name="notification_permission_message">MetaJammer kann Benachrichtigungen anzeigen, um dich über den Fortschritt großer Dateimengen auf dem Laufenden zu halten, während diese im Hintergrund verarbeitet werden. \n\nDies ist besonders nützlich, wenn du zu einer anderen App wechseln möchtest, während MetaJammer seine Arbeit beendet.</string>
