    <string name="hero_title">Schütze deine Privatsphäre</string>
    <string name="hero_subtitle">Bereinige oder ersetze sensible Metadaten, bevor du deine Dateien teilst.</string>
    <string name="feature_images_video_title">Bilder &amp; Video</string>
    <string name="feature_images_video_desc">Vollständige Unterstützung für das Entfernen von Metadaten aus Fotos und das Remuxen von Videos, um Tracking zu unterbinden.</string>
    <string name="feature_poisoning_title">Metadaten-Vergiftung</string>
    <string name="feature_poisoning_desc">Entferne nicht nur Daten – ersetze sie durch realistische Fälschungen, um die Privatsphäre zu wahren und Tracker zu verwirren.</string>
