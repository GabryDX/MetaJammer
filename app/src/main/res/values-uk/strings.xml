    <!-- HelpScreen -->
    <string name="help_title">Довідка та посібники</string>
    <string name="help_item_video_title">Обробка відео</string>
    <string name="help_item_video_body">Підтримувані формати: MP4, MOV.\n\nПовний ремуксинг підтримується для цих контейнерів. Цей процес видаляє GPS, дати та атоми пристрою, щоб захистити вашу конфіденційність.</string>
    <string name="help_item_image_title">Обробка зображень</string>
    <string name="help_item_image_body">Підтримувані формати: JPG, PNG, WebP, HEIF.\n\nMetaJammer видаляє метадані EXIF з цих зображень. У режимі «Отруєння» він замінює конфіденційні теги, такі як координати GPS, реалістичними випадковими даними.</string>
    <string name="help_item_other_title">Обробка PDF та документів</string>
    <string name="help_item_other_body">Формати, що підтримуються: PDF.\n\nMetaJammer тепер повністю підтримує документи PDF. Ви можете читати, видаляти та підміняти («отруювати») метадані, такі як заголовок, автор, тема, ключові слова, автор і виробник, щоб переконатися, що ваші документи чисті перед поширенням.</string>
    <string name="help_report_issue_title">Повідомити про проблему</string>
    <string name="help_report_issue_body">Знайшли помилку або маєте пропозицію щодо функції? Будь ласка, повідомте про це на нашій сторінці GitHub.</string>
    <string name="help_open_github">Відкрити GitHub Issues</string>
    <string name="help_app_version">Версія: %1$s</string>
