    <!-- Dialogs/Permissions -->
    <string name="map_permission_title">Вибір карти та доступ до Інтернету</string>
    <string name="map_permission_message">Для відображення карти при виборі місцезнаходження MetaJammer необхідно підключитися до Інтернету для завантаження фрагментів карти з OpenStreetMap. \n\nЯкщо ви відмовитеся, додаток продовжуватиме відмінно працювати з усіма функціями видалення та отруєння метаданих, але ви не зможете вибирати місцезнаходження візуально на карті.</string>
    <string name="allow_open_map">Дозволити та відкрити карту</string>
    <string name="not_now">Не зараз</string>

    <string name="notification_permission_title">Будьте в курсі</string>
    <string name="notification_permission_message">MetaJammer може показувати сповіщення, щоб тримати вас у курсі прогресу обробки великих партій файлів у фоновому режимі. \n\nЦе особливо корисно, якщо ви хочете переключитися на інший додаток, поки MetaJammer закінчує свою роботу.</string>
