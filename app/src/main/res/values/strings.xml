    <string name="hero_title">Protect Your Privacy</string>
    <string name="hero_subtitle">Clean or replace sensitive metadata before sharing your files.</string>
    <string name="feature_images_video_title">Images &amp; Video</string>
    <string name="feature_images_video_desc">Full support for stripping metadata from photos and remuxing videos to remove tracking.</string>
    <string name="feature_poisoning_title">Metadata Poisoning</string>
    <string name="feature_poisoning_desc">Don’t just remove data—replace it with realistic fakes to preserve privacy and confuse trackers.</string>
    <string name="feature_background_title">Background Processing</string>
    <string name="feature_background_desc">Process hundreds of files efficiently in the background while you do other things.</string>
    <string name="feature_on_device_title">On-Device Privacy</string>
    <string name="feature_on_device_desc">All processing happens locally on your device. Your files never leave MetaJammer.</string>
    <string name="pro_tip_gallery">Pro tip: You can share files directly from your Gallery app into MetaJammer.</string>
