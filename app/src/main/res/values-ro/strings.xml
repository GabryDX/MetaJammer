    <!-- Dialogs/Permissions -->
    <string name="map_permission_title">Selector de hartă și acces la internet</string>
    <string name="map_permission_message">Pentru a afișa o hartă pentru alegerea locației, MetaJammer trebuie să se conecteze la internet pentru a încărca secțiunile de hartă de la OpenStreetMap. \n\nDacă refuzi, aplicația va continua să funcționeze perfect pentru toate funcțiile de eliminare și alterare a metadatelor, dar nu vei putea alege locații vizual pe o hartă.</string>
    <string name="allow_open_map">Permite și deschide harta</string>
    <string name="not_now">Nu acum</string>

    <string name="notification_permission_title">Rămâi informat</string>
    <string name="notification_permission_message">MetaJammer poate afișa notificări pentru a te ține la curent cu progresul loturilor mari de fișiere în timp ce acestea sunt procesate pe fundal. \n\nAcest lucru este util mai ales dacă dorești să comuți la o altă aplicație în timp ce MetaJammer își termină treaba.</string>
