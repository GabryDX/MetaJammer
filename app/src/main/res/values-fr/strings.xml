    <string name="hero_title">Protégez votre vie privée</string>
    <string name="hero_subtitle">Nettoyez ou remplacez les métadonnées sensibles avant de partager vos fichiers.</string>
    <string name="feature_images_video_title">Images et Vidéo</string>
    <string name="feature_images_video_desc">Prise en charge complète de la suppression des métadonnées des photos et du remuxage des vidéos pour éliminer le suivi.</string>
    <string name="feature_poisoning_title">Empoisonnement des métadonnées</string>
    <string name="feature_poisoning_desc">Ne vous contentez pas de supprimer les données — remplacez-les par de faux éléments réalistes pour préserver votre vie privée et tromper les traqueurs.</string>
    <string name="feature_background_title">Traitement en arrière-plan</string>
    <string name="feature_background_desc">Traitez des centaines de fichiers efficacement en arrière-plan pendant que vous faites autre chose.</string>
    <string name="feature_on_device_title">Confidentialité sur l\'appareil</string>
    <string name="feature_on_device_desc">Tout le traitement se fait localement sur votre appareil. Vos fichiers ne quittent jamais MetaJammer.</string>
    <string name="pro_tip_gallery">Astuce : vous pouvez partager des fichiers directement depuis votre application Galerie vers MetaJammer.</string>
