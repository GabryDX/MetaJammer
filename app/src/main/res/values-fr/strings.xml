    <!-- Dialogs/Permissions -->
    <string name="map_permission_title">Sélecteur de carte et accès Internet</string>
    <string name="map_permission_message">Pour afficher une carte permettant de choisir l\'emplacement, MetaJammer doit se connecter à Internet pour charger les tuiles de carte depuis OpenStreetMap. \n\nSi vous refusez, l\'application continuera de fonctionner parfaitement pour toutes les fonctionnalités de suppression et d\'empoisonnement des métadonnées, mais vous ne pourrez pas choisir d\'emplacements visuellement sur une carte.</string>
    <string name="allow_open_map">Autoriser et ouvrir la carte</string>
    <string name="not_now">Pas maintenant</string>

    <string name="notification_permission_title">Restez informé</string>
    <string name="notification_permission_message">MetaJammer peut afficher des notifications pour vous tenir au courant de la progression de grands lots de fichiers pendant qu\'ils sont traités en arrière-plan. \n\nC\'est particulièrement utile si vous souhaitez passer à une autre application pendant que MetaJammer termine son travail.</string>
