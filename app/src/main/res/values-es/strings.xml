    <!-- Dialogs/Permissions -->
    <string name="map_permission_title">Selector de mapa y acceso a Internet</string>
    <string name="map_permission_message">Para mostrar un mapa para elegir la ubicación, MetaJammer necesita conectarse a Internet para cargar los mapas de OpenStreetMap. \n\nSi rechazas, la aplicación seguirá funcionando perfectamente para todas las funciones de eliminación y envenenamiento de metadatos, pero no podrás elegir ubicaciones visualmente en un mapa.</string>
    <string name="allow_open_map">Permitir y abrir mapa</string>
    <string name="not_now">Ahora no</string>

    <string name="notification_permission_title">Mantente informado</string>
    <string name="notification_permission_message">MetaJammer puede mostrar notificaciones para mantenerte actualizado sobre el progreso de grandes lotes de archivos mientras se procesan en segundo plano. \n\nEsto es especialmente útil si quieres cambiar a otra aplicación mientras MetaJammer termina su trabajo.</string>
