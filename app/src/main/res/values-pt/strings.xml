    <!-- Dialogs/Permissions -->
    <string name="map_permission_title">Seletor de Mapa e Acesso à Internet</string>
    <string name="map_permission_message">Para mostrar um mapa para a escolha da localização, o MetaJammer precisa de se ligar à internet para carregar os mapas do OpenStreetMap. \n\nSe recusar, a aplicação continuará a funcionar perfeitamente para todas as funcionalidades de remoção e envenenamento de metadados, mas não poderá escolher localizações visualmente num mapa.</string>
    <string name="allow_open_map">Permitir e Abrir Mapa</string>
    <string name="not_now">Agora Não</string>

    <string name="notification_permission_title">Mantenha-se Informado</string>
    <string name="notification_permission_message">O MetaJammer pode mostrar notificações para o manter atualizado sobre o progresso de grandes lotes de ficheiros enquanto são processados em segundo plano. \n\nIsto é especialmente útil se desejar mudar para outra aplicação enquanto o MetaJammer termina o seu trabalho.</string>
