    <!-- HelpScreen -->
    <string name="help_title">Ajuda e tutoriais</string>
    <string name="help_item_video_title">Processamento de vídeo</string>
    <string name="help_item_video_body">Formatos suportados: MP4, MOV.\n\nO remuxing completo é suportado para estes contentores. Este processo remove GPS, datas e átomos do dispositivo para proteger a sua privacidade.</string>
    <string name="help_item_image_title">Processamento de imagem</string>
    <string name="help_item_image_body">Formatos suportados: JPG, PNG, WebP, HEIF.\n\nO MetaJammer remove os metadados EXIF destas imagens. No modo \"Envenenar\", substitui etiquetas sensíveis como coordenadas GPS por dados aleatórios realistas.</string>
    <string name="help_item_other_title">Processamento de PDF e Documentos</string>
    <string name="help_item_other_body">Formatos suportados: PDF.\n\nO MetaJammer agora suporta totalmente documentos PDF. Você pode ler, remover e \"envenenar\" metadados como Título, Autor, Assunto, Palavras-chave, Criador e Produtor. Ele também remove marcas d\'água ocultas e anotações para garantir que seus documentos estejam limpos antes de serem compartilhados.</string>
    <string name="help_report_issue_title">Comunicar um problema</string>
    <string name="help_report_issue_body">Encontrou um erro ou tem um pedido de funcionalidade? Por favor, reporte na nossa página do GitHub.</string>
    <string name="help_open_github">Abrir problemas no GitHub</string>
    <string name="help_app_version">Versão: %1$s</string>
