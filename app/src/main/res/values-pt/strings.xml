    <!-- Dialogs/Permissions -->
    <string name="map_permission_title">Seletor de mapa e acesso à Internet</string>
    <string name="map_permission_message">Para mostrar um mapa para a escolha da localização, o MetaJammer precisa de se ligar à Internet para carregar mosaicos de mapa do OpenStreetMap. \n\nSe recusar, a aplicação continuará a funcionar perfeitamente para todas as funções de remoção e envenenamento de metadados, mas não poderá escolher localizações visualmente num mapa.</string>
    <string name="allow_open_map">Permitir e Abrir Mapa</string>
    <string name="not_now">Agora não</string>

    <string name="notification_permission_title">Mantenha-se informado</string>
    <string name="notification_permission_message">O MetaJammer pode mostrar notificações para o manter atualizado sobre o progresso de grandes lotes de ficheiros enquanto são processados em segundo plano. \n\nIsto é especialmente útil se pretender mudar para outra aplicação enquanto o MetaJammer termina o seu trabalho.</string>
