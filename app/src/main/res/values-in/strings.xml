    <!-- Dialogs/Permissions -->
    <string name="map_permission_title">Pemilih Peta &amp; Akses Internet</string>
    <string name="map_permission_message">Untuk menampilkan peta guna memilih lokasi, MetaJammer perlu terhubung ke internet untuk memuat ubin peta dari OpenStreetMap. \n\nJika Anda menolak, aplikasi akan tetap berfungsi sempurna untuk semua fitur penghapusan dan peracunan metadata, tetapi Anda tidak akan dapat memilih lokasi secara visual di peta.</string>
    <string name="allow_open_map">Izinkan &amp; Buka Peta</string>
    <string name="not_now">Jangan Sekarang</string>

    <string name="notification_permission_title">Tetap Terinformasi</string>
    <string name="notification_permission_message">MetaJammer dapat menampilkan notifikasi untuk memberi tahu Anda tentang kemajuan batch file besar saat diproses di latar belakang. \n\nIni sangat berguna jika Anda ingin beralih ke aplikasi lain sementara MetaJammer menyelesaikan pekerjaannya.</string>
