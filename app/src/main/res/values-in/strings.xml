    <string name="hero_title">Lindungi Privasi Anda</string>
    <string name="hero_subtitle">Bersihkan atau ganti metadata sensitif sebelum membagikan file Anda.</string>
    <string name="feature_images_video_title">Gambar, Video, Audio &amp; PDF</string>
    <string name="feature_images_video_desc">Dukungan penuh untuk menghapus metadata dari foto, dan melakukan remuxing video, audio, serta dokumen PDF untuk menghapus pelacakan.</string>
    <string name="feature_poisoning_title">Metadata Poisoning</string>
    <string name="feature_poisoning_desc">Jangan hanya menghapus data—ganti dengan data palsu yang realistis untuk menjaga privasi dan membingungkan pelacak.</string>
    <string name="feature_background_title">Pemrosesan Latar Belakang</string>
    <string name="feature_background_desc">Proses ratusan file secara efisien di latar belakang saat Anda melakukan hal lain.</string>
    <string name="feature_on_device_title">Privasi di Perangkat</string>
    <string name="feature_on_device_desc">Semua pemrosesan terjadi secara lokal di perangkat Anda. File Anda tidak pernah meninggalkan MetaJammer.</string>
    <string name="pro_tip_gallery">Tips: Anda dapat membagikan file langsung dari aplikasi Galeri ke MetaJammer.</string>
