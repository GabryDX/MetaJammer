    <!-- Dialogs/Permissions -->
    <string name="map_permission_title">Wybór na mapie i dostęp do Internetu</string>
    <string name="map_permission_message">Aby wyświetlić mapę do wyboru lokalizacji, MetaJammer musi połączyć się z Internetem, aby załadować kafelki mapy z OpenStreetMap. \n\nJeśli odmówisz, aplikacja będzie nadal działać idealnie w zakresie wszystkich funkcji usuwania i zatruwania metadanych, ale nie będziesz mógł wizualnie wybierać lokalizacji na mapie.</string>
    <string name="allow_open_map">Zezwól i otwórz mapę</string>
    <string name="not_now">Nie teraz</string>

    <string name="notification_permission_title">Bądź na bieżąco</string>
    <string name="notification_permission_message">MetaJammer może wyświetlać powiadomienia, aby informować Cię o postępie przetwarzania dużych partii plików w tle. \n\nJest to szczególnie przydatne, jeśli chcesz przełączyć się na inną aplikację, podczas gdy MetaJammer kończy pracę.</string>
