    <string name="not_now">Nie teraz</string>

    <string name="notification_permission_title">Bądź na bieżąco</string>
    <string name="notification_permission_message">MetaJammer może wyświetlać powiadomienia, aby informować Cię o postępie przetwarzania dużych partii plików w tle. \n\nJest to szczególnie przydatne, gdy chcesz przełączyć się do innej aplikacji, podczas gdy MetaJammer kończy swoją pracę.</string>
