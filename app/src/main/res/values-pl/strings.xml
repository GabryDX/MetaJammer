    <!-- HelpScreen -->
    <string name="help_title">Pomoc i poradniki</string>
    <string name="help_item_video_title">Przetwarzanie wideo</string>
    <string name="help_item_video_body">Obsługiwane formaty: MP4, MOV.\n\nPełny remuxing jest obsługiwany dla tych kontenerów. Proces ten usuwa dane GPS, daty i atomy urządzenia, aby chronić Twoją prywatność.</string>
    <string name="help_item_image_title">Przetwarzanie obrazów</string>
    <string name="help_item_image_body">Obsługiwane formaty: JPG, PNG, WebP, HEIF.\n\nMetaJammer usuwa metadane EXIF z tych obrazów. W trybie „Zatruwanie” zastępuje wrażliwe tagi, takie jak współrzędne GPS, realistycznymi losowymi danymi.</string>
    <string name="help_item_other_title">Przetwarzanie dokumentów i plików PDF</string>
    <string name="help_item_other_body">Obsługiwane formaty: PDF.\n\nMetaJammer w pełni obsługuje teraz dokumenty PDF. Możesz czytać, usuwać i „zatruwać” metadane, takie jak tytuł, autor, temat, słowa kluczowe, twórca i producent. Usuwa również ukryte znaki wodne i adnotacje, aby zapewnić, że dokumenty są czyste przed udostępnieniem.</string>
    <string name="help_report_issue_title">Zgłoś problem</string>
    <string name="help_report_issue_body">Znalazłeś błąd lub masz propozycję nowej funkcji? Zgłoś to na naszej stronie GitHub.</string>
