    <!-- HelpScreen -->
    <string name="help_title">Yardım ve Eğitimler</string>
    <string name="help_item_video_title">Video İşleme</string>
    <string name="help_item_video_body">Desteklenen formatlar: MP4, MOV.\n\nBu kapsayıcılar için tam remuxing desteklenir. Bu işlem, gizliliğinizi korumak için GPS, tarih ve cihaz atomlarını kaldırır.</string>
    <string name="help_item_image_title">Görüntü İşleme</string>
    <string name="help_item_image_body">Desteklenen formatlar: JPG, PNG, WebP, HEIF.\n\nMetaJammer bu görüntülerden EXIF metadatalarını temizler. \"Zehirleme\" modunda, GPS koordinatları gibi hassas etiketleri gerçekçi rastgele verilerle değiştirir.</string>
    <string name="help_item_other_title">Diğer Dosyalar</string>
    <string name="help_item_other_body">Desteklenen formatlar: Şu an için yok.\n\nMetaJammer şu anda medya dosyalarına odaklanmaktadır. Gelecek güncellemeler PDF ve belge desteğini içerecektir. Takipte kalın!</string>
    <string name="help_report_issue_title">Sorun Bildir</string>
    <string name="help_report_issue_body">Bir hata mı buldunuz veya bir özellik isteğiniz mi var? Lütfen GitHub sayfamızda bildirin.</string>
    <string name="help_open_github">GitHub Sorunlarını Aç</string>
